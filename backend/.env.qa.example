# =====================================================================
# QA environment template.  On Railway, copy each KEY=VALUE into the
# service's Variables tab.  Locally, copy to .env.qa (not committed).
# =====================================================================

SPRING_PROFILES_ACTIVE=qa
# Railway injects PORT at runtime; application.yml uses ${PORT:8080}.
SERVER_PORT=8080

# ---- Database (Supabase QA project) -------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres.PROJECT_REF_QA
SPRING_DATASOURCE_PASSWORD=REPLACE_ME_WITH_QA_DB_PASSWORD

# ---- JWT -----------------------------------------------------------
# MUST be different from dev and prod.
JWT_SECRET=REPLACE_ME_WITH_A_64_CHAR_RANDOM_STRING_FOR_QA_ONLY
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

# ---- OAuth --------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME

# ---- CORS ---------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://sroadtutor-qa.up.railway.app

# ---- Logging ------------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
