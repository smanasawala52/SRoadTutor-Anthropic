# =====================================================================
# DEV environment template.  Copy to .env.dev (not committed) and fill
# in real values from your Supabase dev project + Google/FB consoles.
# =====================================================================

SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ---- Database (Supabase dev project) ------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres.PROJECT_REF_DEV
SPRING_DATASOURCE_PASSWORD=REPLACE_ME_WITH_DEV_DB_PASSWORD

# ---- JWT -----------------------------------------------------------
# Generate a 64-char random string: `openssl rand -base64 64`
JWT_SECRET=REPLACE_ME_WITH_A_64_CHAR_RANDOM_STRING_FOR_DEV_ONLY_DO_NOT_REUSE
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

# ---- OAuth --------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME
FACEBOOK_OAUTH_APP_ID=REPLACE_ME
FACEBOOK_OAUTH_APP_SECRET=REPLACE_ME

# ---- CORS ---------------------------------------------------------
# Comma-separated. Android emulator uses 10.0.2.2, iOS sim uses localhost.
CORS_ALLOWED_ORIGINS=http://localhost:*,http://10.0.2.2:*,capacitor://localhost,ionic://localhost

# ---- Logging ------------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
