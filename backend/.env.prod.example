# =====================================================================
# PROD environment template.  PROD values live in Railway's Variables tab.
# NEVER put real prod secrets in this file — it gets committed.
# Locally, copy to .env.prod (not committed) only if you must smoke-test
# against prod — otherwise leave it alone.
# =====================================================================

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ---- Database (Supabase PROD project) -----------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres.PROJECT_REF_PROD
SPRING_DATASOURCE_PASSWORD=REPLACE_ME_WITH_PROD_DB_PASSWORD

# ---- JWT -----------------------------------------------------------
# MUST be different from dev and qa.  Rotate at least yearly.
JWT_SECRET=REPLACE_ME_WITH_A_64_CHAR_RANDOM_STRING_FOR_PROD_ONLY
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

# ---- OAuth --------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME
FACEBOOK_OAUTH_APP_ID=REPLACE_ME
FACEBOOK_OAUTH_APP_SECRET=REPLACE_ME

# ---- CORS ---------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://sroadtutor.up.railway.app

# ---- Logging ------------------------------------------------------
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
