#!/bin/sh
# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script (Unix).
# Fetches Maven if missing, then runs it.  Trimmed version of the official
# wrapper (3.3.2).  Do not edit unless you know what you are doing.
# ----------------------------------------------------------------------------
set -e

if [ -z "$JAVA_HOME" ]; then
  JAVA_EXE=$(command -v java || true)
  if [ -z "$JAVA_EXE" ]; then
    echo "Error: JAVA_HOME not set and 'java' not on PATH." >&2
    exit 1
  fi
else
  JAVA_EXE="$JAVA_HOME/bin/java"
fi

BASE_DIR=$(cd "$(dirname "$0")"; pwd)
WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPS="$BASE_DIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$WRAPPER_JAR" ]; then
  WRAPPER_URL=$(grep '^wrapperUrl=' "$WRAPPER_PROPS" | cut -d= -f2-)
  echo "Downloading Maven Wrapper from $WRAPPER_URL"
  mkdir -p "$(dirname "$WRAPPER_JAR")"
  if command -v curl >/dev/null; then
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    wget -O "$WRAPPER_JAR" "$WRAPPER_URL"
  fi
fi

exec "$JAVA_EXE" \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$BASE_DIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
